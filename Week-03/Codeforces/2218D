#include <bits/stdc++.h>
using std::cout;
using std::cin;
using std::vector;
using std::pair;
using std::string;
using std::sort;

int main(){
    std::ios_base::sync_with_stdio(false);
    std::cin.tie(NULL);

    int t;
    std::cin >> t;
    
    while (t--){
        long long n{};
        cin >> n;

        vector<unsigned long long> arr(n);
        auto i = 0ll;
        for(; i < n; ++i){
            auto m = (2*i - 1)*(2*i + 1);
            if(i == 0) arr[i] = 1;
            else if(i == n-1) arr[i] = 2*i - 1;
            else arr[i] = m;
        }

        for(auto num : arr) cout << num << " ";
        cout << '\n';
    }
}
