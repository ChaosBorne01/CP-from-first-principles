#include <bits/stdc++.h>
using namespace std;

int main(){
    std::ios_base::sync_with_stdio(false);
    std::cin.tie(NULL);

    int t;
    std::cin >> t;
    
    while (t--){
        int n{};
        cin >> n;

        vector<int> arr(n);
        for(auto i = 0; i < n; ++i) cin >> arr[i];

        int h{arr[0]};
        long long s{h};
        for(auto i = 1; i < n; ++i){
            if(arr[i] >= h){
                arr[i] = h;
            }
            else{
                h = arr[i];
            }
            s += h;
        }

        cout << s << '\n';
    }
}
