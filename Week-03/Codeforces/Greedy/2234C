#include <bits/stdc++.h>
using namespace std;

int main(){
    std::ios_base::sync_with_stdio(false);
    std::cin.tie(NULL);

    int t;
    std::cin >> t;
    
    while (t--){
        long long n{};
        cin >> n;

        vector<long long> h(n);
        for(auto i = 0; i < n; ++i) cin >> h[i];

        long long maxi{0};
        for(long long j = 1; j != n; ++j){
            if(h[j] > h[maxi]) maxi = j;
        }

        vector<long long> w(n);

        for(auto i = 0; i < n; ++i){
            long long r{0};
            for(long long j = i; j%n != maxi; ++j){
                if(h[j%n] > r) r = h[j%n];
                w[i] += r;
            }

            long long l{};
            for(long long j = (i-1 >= 0 ? (i-1) : (n-1)); j != maxi; --j){
                if(j < 0) j += n;
                if(j == maxi) break;
                if(h[j] > l) l = h[j];
                w[i] += l;
            }
        }
        for(auto x : w){
            cout << x << " ";
        }
        cout << '\n';
    }
}
