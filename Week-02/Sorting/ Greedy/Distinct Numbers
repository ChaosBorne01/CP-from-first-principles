#include <bits/stdc++.h>
using std::cout;
using std::cin;
using std::vector;
using std::pair;
using std::string;
using std::sort;
using std::set;
 
int main(){
    std::ios_base::sync_with_stdio(false);
    std::cin.tie(NULL);
 
    long long n{};
    cin >> n;
 
    vector<long long> a(n);
    for(auto i = 0ll; i < n; ++i) cin >> a[i];
 
 
    sort(a.begin(), a.end());
 
    long long tmp{a[0]};
    long long dc{1};
    for(auto i = 1ll; i < n; ++i){
        if(a[i] != tmp){
            tmp = a[i];
            dc++;
        }
    }
 
    cout << dc << '\n';
}