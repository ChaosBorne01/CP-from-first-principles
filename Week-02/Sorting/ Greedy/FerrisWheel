#include <bits/stdc++.h>
using std::cout;
using std::cin;
using std::vector;
using std::pair;
using std::string;
using std::sort;
using std::set;
 
int main(){
    std::ios_base::sync_with_stdio(false);
    std::cin.tie(NULL);
 
    long long n{}, x{};
    cin >> n >> x;
 
    vector<long long> w(n);
    for(auto i = 0ll; i < n; ++i) cin >> w[i];
 
    sort(w.begin(), w.end());
 
    long long l{}, r{n-1};
    long long rides{};
 
    long long c{};
    while(c != n){
        if(l != r){
            if(w[r] + w[l] <= x){
                r--;
                l++;
                c += 2;
                rides++;
            }
            else{
                r--;
                c++;
                rides++;
            }
        }
        else{
            c++;
            rides++;
        }
    }
 
    cout << rides << '\n';
}