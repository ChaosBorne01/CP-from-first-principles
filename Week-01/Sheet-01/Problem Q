#include <iostream>

int main(){
    std::ios_base::sync_with_stdio(false);
    std::cin.tie(NULL);

    int a{}, b{};
    char s{};
    std::cin >> a >> s >> b;

    if(s == '+') std::cout << a+b << '\n';
    else if(s == '-') std::cout << a-b << '\n';
    else if(s == '*') std::cout << a*b << '\n';
    else std::cout << a/b << '\n';
}
