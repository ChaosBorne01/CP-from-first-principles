#include <bits/stdc++.h>
using std::cout;
using std::cin;
using std::vector;
using std::pair;
using std::string;
using std::sort;
using std::set;

int main(){
    std::ios_base::sync_with_stdio(false);
    std::cin.tie(NULL);

    long long a{}, b{}, x{}, y{};
    cin >> a >> b >> x >> y;

    vector<long long> ord = {a, b ,x , y};
    sort(ord.begin(), ord.end());

    if((ord[0] + ord[1]) == (a + x)) cout << ord[1] << " " << ord[2] << '\n';
    else cout << -1 << '\n';
}
